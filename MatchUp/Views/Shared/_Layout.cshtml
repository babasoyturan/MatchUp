@{
    var isAuthenticated = User.Identity?.IsAuthenticated ?? false;
    var accountText = User.Identity?.Name ?? "Account";
}

<!DOCTYPE html>
<html lang="en">
<head>
    <meta charset="utf-8">
    <title>@ViewData["Title"] - MatchUp</title>
    <meta name="viewport" content="width=device-width, initial-scale=1, shrink-to-fit=no">

    <link href="~/assets/css/main.css" rel="stylesheet" media="screen">

    <link rel="shortcut icon" href="~/img/icons/favicon.ico">
    <link rel="apple-touch-icon" href="~/img/icons/apple-touch-icon.png">

    <style>
        .header-2 .mainmenu .sf-menu,
        .header-2 .mainmenu .sf-menu > li,
        .header-2 .mainmenu .sf-menu > li > a {
            position: relative;
        }

            .header-2 .mainmenu .sf-menu > li {
                position: relative;
            }

                .header-2 .mainmenu .sf-menu > li > ul,
                .header-2 .mainmenu .sf-menu > li > ul.sub-current {
                    left: 0 !important;
                    right: auto !important;
                    top: 100% !important;
                    margin-top: 0 !important;
                    min-width: 220px;
                    z-index: 99999;
                }

                .header-2 .mainmenu .sf-menu > li > .sf-mega {
                    left: 0 !important;
                    right: auto !important;
                    top: 100% !important;
                    z-index: 99999;
                }

                .header-2 .mainmenu .sf-menu > li.menu-right > ul,
                .header-2 .mainmenu .sf-menu > li.menu-right > ul.sub-current,
                .header-2 .mainmenu .sf-menu > li.menu-right > .sf-mega {
                    left: auto !important;
                    right: 0 !important;
                }

            .header-2 .mainmenu .sf-menu li ul li {
                position: relative;
            }

                .header-2 .mainmenu .sf-menu li ul li ul {
                    left: 100% !important;
                    right: auto !important;
                    top: 0 !important;
                }

            .header-2 .mainmenu .sf-menu > li.menu-right ul li ul {
                left: auto !important;
                right: 100% !important;
            }

            .header-2 .mainmenu .sf-menu > li > ul li a,
            .header-2 .mainmenu .sf-menu > li > ul li button {
                display: block;
                width: 100%;
                text-align: left;
                white-space: nowrap;
            }

        .menu-logout-form {
            margin: 0;
        }

        .menu-logout-btn {
            width: 100%;
            background: transparent;
            border: 0;
            padding: 14px 18px;
            color: #555;
            font-size: 14px;
            text-align: left;
            cursor: pointer;
            transition: all .2s ease;
        }

            .menu-logout-btn:hover {
                background: #f5f5f5;
                color: #111;
            }

        .mobile-nav-account-title {
            font-weight: 600;
        }

        .mainmenu .sf-menu > li > a {
            text-decoration: none !important;
        }

        .mainmenu .sf-menu > li > ul li a {
            text-decoration: none !important;
        }
    </style>
</head>

<body>
    <div id="layout">
        <header class="header-2">
            <div class="headerbox">
                <div class="container">
                    <div class="row justify-content-between align-items-center">
                        <div class="col col-xl-2">
                            <div class="logo">
                                <a asp-controller="Home" asp-action="Index" title="Return Home">
                                    <img src="~/img/logo.png" alt="Logo" class="logo_img">
                                </a>
                            </div>
                        </div>

                        <div class="col col-xl-10">
                            <nav class="mainmenu">
                                <div class="container">
                                    <ul class="sf-menu" id="menu">
                                        <li>
                                            <a asp-controller="Home" asp-action="Index">Home</a>
                                        </li>

                                        <li>
                                            <a href="#">Platform</a>
                                            <ul class="sub-current">
                                                @if (isAuthenticated)
                                                {
                                                    <li>
                                                        <a asp-controller="Teams" asp-action="Mine">My Teams</a>
                                                    </li>
                                                    <li>
                                                        <a asp-controller="Notifications" asp-action="Index">My Notifications</a>
                                                    </li>
                                                    <li>
                                                        <a asp-controller="Teams" asp-action="Mine">My Activity</a>
                                                    </li>
                                                }
                                                else
                                                {
                                                    <li>
                                                        <a asp-controller="Account" asp-action="Login">Login</a>
                                                    </li>
                                                    <li>
                                                        <a asp-controller="Account" asp-action="Register">Register</a>
                                                    </li>
                                                }
                                            </ul>
                                        </li>

                                        <li>
                                            <a asp-controller="Teams" asp-action="Index">Teams</a>
                                            <ul class="sub-current">
                                                <li>
                                                    <a asp-controller="Teams" asp-action="Index">Teams List</a>
                                                </li>
                                                @if (isAuthenticated)
                                                {
                                                    <li>
                                                        <a asp-controller="Teams" asp-action="Mine">My Teams</a>
                                                    </li>
                                                    <li>
                                                        <a asp-controller="Teams" asp-action="Create">Create Team</a>
                                                    </li>
                                                }
                                            </ul>
                                        </li>

                                        <li>
                                            <a asp-controller="Players" asp-action="Index">Players</a>
                                        </li>

                                        <li>
                                            <a asp-controller="Matches" asp-action="Index">Fixtures</a>
                                        </li>

                                        <li>
                                            <a asp-controller="Matches" asp-action="Results">Results</a>
                                        </li>

                                        <li>
                                            <a asp-controller="Teams" asp-action="Index" asp-fragment="open-to-game">Open To Game</a>
                                        </li>

                                        @if (isAuthenticated)
                                        {
                                            <li>
                                                <a asp-controller="Notifications" asp-action="Index">Notifications</a>
                                            </li>

                                            <li class="menu-right">
                                                <a href="#">@accountText</a>
                                                <ul class="sub-current">
                                                    <li>
                                                        <a asp-controller="Teams" asp-action="Mine">My Teams</a>
                                                    </li>
                                                    <li>
                                                        <a asp-controller="Notifications" asp-action="Index">My Notifications</a>
                                                    </li>
                                                    <li>
                                                        <form asp-controller="Account"
                                                              asp-action="Logout"
                                                              method="post"
                                                              class="menu-logout-form">
                                                            @Html.AntiForgeryToken()
                                                            <button type="submit" class="menu-logout-btn">Logout</button>
                                                        </form>
                                                    </li>
                                                </ul>
                                            </li>
                                        }
                                        else
                                        {
                                            <li class="menu-right">
                                                <a href="#">Account</a>
                                                <ul class="sub-current">
                                                    <li>
                                                        <a asp-controller="Account" asp-action="Login">Login</a>
                                                    </li>
                                                    <li>
                                                        <a asp-controller="Account" asp-action="Register">Register</a>
                                                    </li>
                                                </ul>
                                            </li>
                                        }
                                    </ul>
                                </div>
                            </nav>

                            <a class="mobile-nav" href="#mobile-nav">
                                <i class="fa fa-bars"></i>
                            </a>
                        </div>
                    </div>
                </div>
            </div>
        </header>

        <div id="mobile-nav">
            <ul>
                <li>
                    <a asp-controller="Home" asp-action="Index">Home</a>
                </li>

                <li>
                    <a href="#">Platform</a>
                    <ul>
                        @if (isAuthenticated)
                        {
                            <li>
                                <a asp-controller="Teams" asp-action="Mine">My Teams</a>
                            </li>
                            <li>
                                <a asp-controller="Notifications" asp-action="Index">My Notifications</a>
                            </li>
                        }
                        else
                        {
                            <li>
                                <a asp-controller="Account" asp-action="Login">Login</a>
                            </li>
                            <li>
                                <a asp-controller="Account" asp-action="Register">Register</a>
                            </li>
                        }
                    </ul>
                </li>

                <li>
                    <a asp-controller="Teams" asp-action="Index">Teams</a>
                    <ul>
                        <li>
                            <a asp-controller="Teams" asp-action="Index">Teams List</a>
                        </li>
                        @if (isAuthenticated)
                        {
                            <li>
                                <a asp-controller="Teams" asp-action="Mine">My Teams</a>
                            </li>
                            <li>
                                <a asp-controller="Teams" asp-action="Create">Create Team</a>
                            </li>
                        }
                    </ul>
                </li>

                <li>
                    <a asp-controller="Players" asp-action="Index">Players</a>
                </li>

                <li>
                    <a asp-controller="Matches" asp-action="Index">Fixtures</a>
                </li>

                <li>
                    <a asp-controller="Matches" asp-action="Results">Results</a>
                </li>

                <li>
                    <a asp-controller="Teams" asp-action="Index" asp-fragment="open-to-game">Open To Game</a>
                </li>

                @if (isAuthenticated)
                {
                    <li>
                        <a asp-controller="Notifications" asp-action="Index">Notifications</a>
                    </li>

                    <li>
                        <a href="#" class="mobile-nav-account-title">@accountText</a>
                        <ul>
                            <li>
                                <a asp-controller="Teams" asp-action="Mine">My Teams</a>
                            </li>
                            <li>
                                <a asp-controller="Notifications" asp-action="Index">My Notifications</a>
                            </li>
                            <li>
                                <form asp-controller="Account"
                                      asp-action="Logout"
                                      method="post"
                                      class="menu-logout-form">
                                    @Html.AntiForgeryToken()
                                    <button type="submit" class="menu-logout-btn">Logout</button>
                                </form>
                            </li>
                        </ul>
                    </li>
                }
                else
                {
                    <li>
                        <a href="#">Account</a>
                        <ul>
                            <li>
                                <a asp-controller="Account" asp-action="Login">Login</a>
                            </li>
                            <li>
                                <a asp-controller="Account" asp-action="Register">Register</a>
                            </li>
                        </ul>
                    </li>
                }
            </ul>
        </div>

        @RenderBody()

        <footer id="footer">
            <div class="top-footer">
                <div class="col-lg-12">
                    <div class="logo-footer">
                        <h2>Match Up</h2>
                    </div>
                </div>

                <ul class="social">
                    <li><div><a href="#" class="facebook"><i class="fa fa-facebook"></i></a></div></li>
                    <li><div><a href="#" class="twitter-icon"><i class="fa fa-twitter"></i></a></div></li>
                    <li><div><a href="#" class="vimeo"><i class="fa fa-vimeo-square"></i></a></div></li>
                    <li><div><a href="#" class="google-plus"><i class="fa fa-google-plus"></i></a></div></li>
                    <li><div><a href="#" class="youtube"><i class="fa fa-youtube"></i></a></div></li>
                </ul>
            </div>

            <div class="links-footer">
                <div class="container">
                    <div class="row">
                        <div class="col-lg-2 col-md-5 col-sm-5">
                            <div class="info-links">
                                <h5>Platform</h5>
                                <ul>
                                    <li><a asp-controller="Home" asp-action="Index">Home</a></li>
                                    <li><a asp-controller="Teams" asp-action="Index">Teams</a></li>
                                    <li><a asp-controller="Players" asp-action="Index">Players</a></li>
                                    <li><a asp-controller="Matches" asp-action="Index">Fixtures</a></li>
                                </ul>
                            </div>
                        </div>

                        <div class="col-lg-4 col-md-7 col-sm-7">
                            <div class="info-links">
                                <h5>Matches</h5>
                                <ul class="columns">
                                    <li><a asp-controller="Matches" asp-action="Results">Results</a></li>
                                    <li><a asp-controller="Teams" asp-action="Index" asp-fragment="open-to-game">Open To Game</a></li>
                                    <li><a asp-controller="Notifications" asp-action="Index">Notifications</a></li>
                                    <li><a asp-controller="Home" asp-action="NotFoundPage">404 Page</a></li>
                                </ul>
                            </div>
                        </div>

                        <div class="col-lg-2 col-md-5 col-sm-5">
                            <div class="info-links">
                                <h5>Quick Links</h5>
                                <ul>
                                    <li><a asp-controller="Home" asp-action="Index">Statistics</a></li>
                                    <li><a asp-controller="Teams" asp-action="Index">Browse Teams</a></li>
                                    <li><a asp-controller="Players" asp-action="Index">Browse Players</a></li>
                                    <li><a asp-controller="Matches" asp-action="Results">Confirmed Results</a></li>
                                </ul>
                            </div>
                        </div>

                        <div class="col-lg-4 col-md-7 col-sm-7">
                            <div class="info-links">
                                <h5>About MatchUp</h5>
                                <ul class="columns">
                                    <li><a href="#">Community Football</a></li>
                                    <li><a href="#">Team Management</a></li>
                                    <li><a href="#">Venue Agreement</a></li>
                                    <li><a href="#">Result Confirmation</a></li>
                                    <li><a href="#">Player Profiles</a></li>
                                    <li><a href="#">Notifications</a></li>
                                    <li><a href="#">Open To Game</a></li>
                                    <li><a href="#">Match Scheduling</a></li>
                                </ul>
                            </div>
                        </div>
                    </div>
                </div>
            </div>
        </footer>

        <div class="footer-down">
            <div class="container">
                <div class="row">
                    <div class="col-md-12">
                        <p>&copy; @DateTime.UtcNow.Year MatchUp. All Rights Reserved</p>
                    </div>
                </div>
            </div>
        </div>
    </div>

    <script type="text/javascript" src="~/assets/js/jquery.js"></script>
    <script type="text/javascript" src="~/assets/js/popper.min.js"></script>
    <script type="text/javascript" src="~/assets/js/bootstrap.min.js"></script>
    <script type="text/javascript" src="~/assets/js/theme-scripts.js"></script>
    <script type="text/javascript" src="~/assets/js/theme-main.js"></script>

    @RenderSection("Scripts", required: false)
</body>
</html>