@model CreateTeamVm

@{
    ViewData["Title"] = "Create Team";
}

<section class="content-info">
    <div class="container paddings">
        <div class="panel-box block-form">
            <div class="titles text-center">
                <h4>CREATE YOUR TEAM</h4>
            </div>

            <div class="info-panel">
                <div class="row">
                    <div class="col-md-12 text-center">
                        <p class="lead">
                            Create your club and start building your squad.
                        </p>
                    </div>
                </div>

                <form asp-controller="Teams"
                      asp-action="Create"
                      method="post"
                      enctype="multipart/form-data">

                    @Html.AntiForgeryToken()

                    <div asp-validation-summary="ModelOnly" class="text-danger margin-bottom-10"></div>

                    <div class="form-group">
                        <label asp-for="Name" class="control-label col-sm-2">Team Name</label>
                        <div class="col-sm-10">
                            <input asp-for="Name" class="form-control" placeholder="Type your team name" />
                            <span asp-validation-for="Name" class="text-danger"></span>
                        </div>
                    </div>

                    <div class="form-group">
                        <label asp-for="Description" class="control-label col-sm-2">Description</label>
                        <div class="col-sm-10">
                            <textarea asp-for="Description"
                                      class="form-control"
                                      rows="4"
                                      placeholder="Write a short team description"></textarea>
                            <span asp-validation-for="Description" class="text-danger"></span>
                        </div>
                    </div>

                    <div class="form-group">
                        <label asp-for="LogoFile" class="control-label col-sm-2">Team Logo</label>
                        <div class="col-sm-10">
                            <input asp-for="LogoFile" type="file" class="form-control" />
                            <span asp-validation-for="LogoFile" class="text-danger"></span>
                        </div>
                    </div>

                    <div class="form-group">
                        <label asp-for="ImageFile" class="control-label col-sm-2">Team Banner Image</label>
                        <div class="col-sm-10">
                            <input asp-for="ImageFile" type="file" class="form-control" />
                            <span asp-validation-for="ImageFile" class="text-danger"></span>
                        </div>
                    </div>

                    <div class="form-group">
                        <label asp-for="OwnerSquadNumber" class="control-label col-sm-2">Your Squad Number</label>
                        <div class="col-sm-10">
                            <input asp-for="OwnerSquadNumber" class="form-control" placeholder="Choose your squad number" />
                            <span asp-validation-for="OwnerSquadNumber" class="text-danger"></span>
                        </div>
                    </div>

                    <div class="form-group">
                        <div class="col-sm-offset-2 col-sm-10">
                            <button type="submit" class="bnt btn-iw">Create Team</button>
                        </div>
                    </div>
                </form>
            </div>
        </div>
    </div>
</section>

@section Scripts {
    <partial name="_ValidationScriptsPartial" />
}