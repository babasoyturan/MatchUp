@model MatchUp.ViewModels.Teams.MineTeamsVm
@using MatchUp.ViewModels.Teams

@{
    ViewData["Title"] = "My Teams";
}

<div class="section-title" style="background:url('/img/slide/1.jpg')">
    <div class="container">
        <div class="row">
            <div class="col-md-8">
                <h1>My Teams</h1>
            </div>

            <div class="col-md-4">
                <div class="breadcrumbs">
                    <ul>
                        <li><a asp-controller="Home" asp-action="Index">Home</a></li>
                        <li>My Teams</li>
                    </ul>
                </div>
            </div>
        </div>
    </div>
</div>

<section class="content-info">
    <div class="portfolioFilter">
        <div class="container d-flex justify-content-between align-items-center flex-wrap">
            <div>
                <h5 style="display:inline-block; margin-right:15px;">
                    <i class="fa fa-filter" aria-hidden="true"></i> Filter By:
                </h5>

                <a href="#"
                   class="my-teams-filter-link @(Model.FilterBy == MyTeamsFilterBy.All ? "current" : "")"
                   data-filter="@((int)MyTeamsFilterBy.All)">
                    Show All
                </a>

                <a href="#"
                   class="my-teams-filter-link @(Model.FilterBy == MyTeamsFilterBy.Member ? "current" : "")"
                   data-filter="@((int)MyTeamsFilterBy.Member)">
                    Member Teams
                </a>

                <a href="#"
                   class="my-teams-filter-link @(Model.FilterBy == MyTeamsFilterBy.Owner ? "current" : "")"
                   data-filter="@((int)MyTeamsFilterBy.Owner)">
                    Owner Teams
                </a>
            </div>

            @if (!Model.HasOwnedTeam)
            {
                <div style="margin-top:10px; margin-bottom:10px;">
                    <a asp-controller="Teams"
                       asp-action="Create"
                       class="btn btn-primary"
                       style="padding:8px 16px;">
                        Create Team
                    </a>
                </div>
            }
        </div>
    </div>

    <div class="container padding-top">
        <form id="mineTeamsFilterForm">
            <input type="hidden" id="FilterBy" name="filterBy" value="@((int)Model.FilterBy)" />

            <div id="mine-teams-results">
                @await Html.PartialAsync("_MineTeamsListPartial", Model)
            </div>
        </form>
    </div>
</section>

@section Scripts {
    <script>
        $(function () {
            function loadMineTeams() {
                const url = '@Url.Action("MinePartial", "Teams")';
                const data = $('#mineTeamsFilterForm').serialize();

                $.get(url, data, function (html) {
                    $('#mine-teams-results').html(html);
                });
            }

            $('.my-teams-filter-link').on('click', function (e) {
                e.preventDefault();

                const filterValue = $(this).data('filter');
                $('#FilterBy').val(filterValue);

                $('.my-teams-filter-link').removeClass('current');
                $(this).addClass('current');

                loadMineTeams();
            });
        });
    </script>
}