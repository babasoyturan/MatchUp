@model MatchDetailsVm

@{
    ViewData["Title"] = "Match Details";

    var homeLogo = !string.IsNullOrWhiteSpace(Model.HomeTeamLogoUrl)
        ? Model.HomeTeamLogoUrl
        : Url.Content("~/img/default-team-logo.png");

    var awayLogo = !string.IsNullOrWhiteSpace(Model.AwayTeamLogoUrl)
        ? Model.AwayTeamLogoUrl
        : Url.Content("~/img/default-team-logo.png");

    var heroImage = !string.IsNullOrWhiteSpace(Model.VenueHeroImageUrl)
        ? Model.VenueHeroImageUrl
        : Url.Content("~/img/locations/1.jpg");

    var hasConfirmedScore = !string.IsNullOrWhiteSpace(Model.ConfirmedScoreText);
    var heroCenterText = hasConfirmedScore ? Model.ConfirmedScoreText : "VS";
}

<style>
    .match-details-section {
        padding-top: 30px;
        padding-bottom: 90px;
    }

    .match-tabs-wrapper {
        margin-top: 20px;
    }

    .match-team-logo-box {
        width: 260px;
        height: 260px;
        margin: 0 auto 20px auto;
        display: flex;
        align-items: center;
        justify-content: center;
    }

        .match-team-logo-box img {
            width: 100%;
            height: 100%;
            object-fit: contain;
        }

    .match-team-name {
        display: inline-block;
        font-size: 36px;
        font-weight: 700;
        color: #fff !important;
        text-decoration: none !important;
        margin-top: 10px;
    }

        .match-team-name:hover,
        .match-team-name:focus {
            color: #00d084 !important;
            text-decoration: none !important;
        }

    .match-action-btn {
        display: inline-block;
        min-width: 220px;
        text-align: center;
        padding: 14px 26px;
        font-size: 18px;
        font-weight: 600;
        border-radius: 4px;
        text-decoration: none !important;
        transition: all 0.2s ease-in-out;
    }

    .btn.theme.match-action-btn,
    .btn.theme.match-action-btn:visited,
    .btn.theme.match-action-btn:active,
    .btn.theme.match-action-btn:focus {
        color: #ffffff !important;
        text-decoration: none !important;
    }

        .btn.theme.match-action-btn i,
        .btn.theme.match-action-btn:visited i,
        .btn.theme.match-action-btn:active i,
        .btn.theme.match-action-btn:focus i {
            color: #ffffff !important;
        }

        .btn.theme.match-action-btn:hover {
            color: #ffffff !important;
            text-decoration: none !important;
            opacity: 0.92;
        }

            .btn.theme.match-action-btn:hover i {
                color: #ffffff !important;
            }

    .match-main-box,
    .match-side-box,
    .match-table-box {
        margin-bottom: 30px;
    }

    .match-table-wrapper {
        padding: 25px;
    }

        .match-table-wrapper table {
            margin-bottom: 0;
        }

        .match-table-wrapper td,
        .match-table-wrapper th {
            vertical-align: middle !important;
        }

    .match-table-note {
        padding: 40px 20px;
        text-align: center;
    }

    .match-overview-box .info-panel p,
    .match-side-box .info-panel p {
        margin-bottom: 12px;
    }

    .match-hero-score {
        display: inline-block;
        min-width: 120px;
        padding: 16px 24px;
        font-size: 34px;
        font-weight: 700;
        line-height: 1;
        text-align: center;
        background: #00d084;
        color: #ffffff;
        border-radius: 4px;
    }

    .match-proposal-score {
        font-weight: 700;
        font-size: 16px;
    }

    .proposal-action-form {
        display: inline-block;
        margin: 3px 6px 3px 0;
    }

    .match-status-badge {
        display: inline-block;
        padding: 6px 12px;
        border-radius: 20px;
        font-size: 13px;
        font-weight: 600;
        background: #f3f3f3;
    }
</style>

<div class="section-title single-result" style="background:url('@heroImage') center center / cover no-repeat;">
    <div class="container">
        <div class="row">
            <div class="col-lg-12">
                <div class="result-location">
                    <ul>
                        <li>@Model.StartAtUtc.ToString("dd MMM yyyy")</li>
                        <li>
                            <i class="fa fa-map-marker" aria-hidden="true"></i>
                            @Model.CurrentVenueText
                        </li>
                        <li>@Model.Format</li>
                    </ul>
                </div>
            </div>
        </div>

        <div class="row">
            <div class="col-md-5 col-lg-5">
                <div class="team text-center">
                    <div class="match-team-logo-box">
                        <img src="@homeLogo" alt="@Model.HomeTeamName">
                    </div>

                    <a asp-controller="Teams"
                       asp-action="Details"
                       asp-route-id="@Model.HomeTeamId"
                       class="match-team-name">
                        @Model.HomeTeamName
                    </a>
                </div>
            </div>

            <div class="col-md-2 col-lg-2">
                <div class="result-match">
                    @if (hasConfirmedScore)
                    {
                        <div class="match-hero-score">@heroCenterText</div>
                    }
                    else
                    {
                        <span>VS</span>
                    }
                </div>
            </div>

            <div class="col-md-5 col-lg-5">
                <div class="team right text-center">
                    <div class="match-team-logo-box">
                        <img src="@awayLogo" alt="@Model.AwayTeamName">
                    </div>

                    <a asp-controller="Teams"
                       asp-action="Details"
                       asp-route-id="@Model.AwayTeamId"
                       class="match-team-name">
                        @Model.AwayTeamName
                    </a>
                </div>
            </div>
        </div>
    </div>
</div>

<section class="content-info match-details-section">
    <div class="single-team-tabs match-tabs-wrapper">
        <div class="container">
            <div class="row">
                <div class="col-xl-12 col-md-12">
                    <ul class="nav nav-tabs" id="myTab">
                        <li class="active"><a href="#overview" data-toggle="tab">Overview</a></li>
                        <li><a href="#venue-history" data-toggle="tab">Venue Proposals</a></li>
                        <li><a href="#result-history" data-toggle="tab">Result Proposals</a></li>
                    </ul>
                </div>

                <div class="col-lg-12">
                    <div class="tab-content">
                        <div class="tab-pane active" id="overview">
                            <div class="row">
                                <div class="col-lg-8">
                                    <div class="panel-box padding-b match-main-box match-overview-box">
                                        <div class="titles">
                                            <h4>Match Overview</h4>
                                        </div>

                                        <div class="info-panel">
                                            <p><strong>Home Team:</strong> @Model.HomeTeamName</p>
                                            <p><strong>Away Team:</strong> @Model.AwayTeamName</p>
                                            <p><strong>Start Time:</strong> @Model.StartAtUtc.ToString("dd MMM yyyy HH:mm")</p>
                                            <p><strong>Duration:</strong> @Model.DurationMinutes min</p>
                                            <p><strong>Format:</strong> @Model.Format</p>
                                            <p><strong>Match Status:</strong> @Model.Status</p>
                                            <p><strong>Venue Status:</strong> @Model.VenueStatus</p>
                                            <p><strong>Result Status:</strong> @Model.ResultStatus</p>
                                            <p><strong>Current Venue:</strong> @Model.CurrentVenueText</p>

                                            @if (!string.IsNullOrWhiteSpace(Model.ConfirmedScoreText))
                                            {
                                                <p><strong>Confirmed Score:</strong> @Model.ConfirmedScoreText</p>
                                            }
                                        </div>
                                    </div>

                                    <div class="panel-box match-main-box">
                                        <div class="titles no-margin">
                                            <h4>Venue Management</h4>
                                        </div>

                                        <div class="info-panel">
                                            @if (Model.CanProposeVenue)
                                            {
                                                <a asp-controller="Matches"
                                                   asp-action="ProposeVenue"
                                                   asp-route-matchId="@Model.Id"
                                                   class="btn theme match-action-btn">
                                                    Propose Venue
                                                    <i class="fa fa-angle-right" aria-hidden="true"></i>
                                                </a>
                                            }
                                            else if (Model.HasPendingVenueProposal)
                                            {
                                                <p>A pending venue proposal already exists for this match.</p>
                                            }
                                            else
                                            {
                                                <p>You cannot propose a venue for this match right now.</p>
                                            }
                                        </div>
                                    </div>

                                    <div class="panel-box match-main-box">
                                        <div class="titles no-margin">
                                            <h4>Result Management</h4>
                                        </div>

                                        <div class="info-panel">
                                            @if (Model.CanProposeResult)
                                            {
                                                <a asp-controller="Matches"
                                                   asp-action="ProposeResult"
                                                   asp-route-matchId="@Model.Id"
                                                   class="btn theme match-action-btn">
                                                    Propose Result
                                                    <i class="fa fa-angle-right" aria-hidden="true"></i>
                                                </a>
                                            }
                                            else if (Model.HasPendingResultProposal)
                                            {
                                                <p>A pending result proposal already exists for this match.</p>
                                            }
                                            else if (!string.IsNullOrWhiteSpace(Model.ConfirmedScoreText))
                                            {
                                                <p>This match result has already been confirmed.</p>
                                            }
                                            else
                                            {
                                                <p>You cannot propose a result for this match right now.</p>
                                            }
                                        </div>
                                    </div>
                                </div>

                                <div class="col-lg-4">
                                    <div class="panel-box match-side-box">
                                        <div class="titles no-margin">
                                            <h4>Side Info</h4>
                                        </div>

                                        <div class="info-panel">
                                            <p>
                                                <strong>Your Access:</strong>
                                                @if (Model.IsHomeOwnerView || Model.IsAwayOwnerView)
                                                {
                                                    <span>Owner</span>
                                                }
                                                else
                                                {
                                                    <span>Viewer</span>
                                                }
                                            </p>

                                            <p><strong>Home Team:</strong> @Model.HomeTeamName</p>
                                            <p><strong>Away Team:</strong> @Model.AwayTeamName</p>
                                            <p><strong>Venue:</strong> @Model.CurrentVenueText</p>
                                            <p><strong>Result Status:</strong> @Model.ResultStatus</p>

                                            @if (!string.IsNullOrWhiteSpace(Model.ConfirmedScoreText))
                                            {
                                                <p><strong>Score:</strong> @Model.ConfirmedScoreText</p>
                                            }
                                        </div>
                                    </div>
                                </div>
                            </div>
                        </div>

                        <div class="tab-pane" id="venue-history">
                            <div class="row">
                                <div class="col-lg-12">
                                    @if (!Model.VenueProposals.Any())
                                    {
                                        <div class="panel-box match-table-box">
                                            <div class="match-table-note">
                                                <h4>No venue proposals yet</h4>
                                                <p>No team has submitted a venue proposal for this match.</p>
                                            </div>
                                        </div>
                                    }
                                    else
                                    {
                                        <div class="panel-box match-table-box">
                                            <div class="titles">
                                                <h4>Venue Proposal History</h4>
                                            </div>

                                            <div class="match-table-wrapper">
                                                <table class="table-striped table-responsive table-hover result-point">
                                                    <thead class="point-table-head">
                                                        <tr>
                                                            <th class="text-left">Proposed By</th>
                                                            <th class="text-left">Venue Kind</th>
                                                            <th class="text-left">Venue</th>
                                                            <th class="text-center">Status</th>
                                                            <th class="text-center">Created</th>
                                                            <th class="text-center">Responded</th>
                                                            <th class="text-center">Actions</th>
                                                        </tr>
                                                    </thead>

                                                    <tbody>
                                                        @foreach (var proposal in Model.VenueProposals)
                                                        {
                                                            <tr>
                                                                <td class="text-left">@proposal.ProposedByTeamName</td>
                                                                <td class="text-left">@proposal.VenueKindText</td>
                                                                <td class="text-left">@proposal.VenueText</td>
                                                                <td class="text-center">@proposal.StatusText</td>
                                                                <td class="text-center">@proposal.CreatedAtUtc.ToString("dd MMM yyyy HH:mm")</td>
                                                                <td class="text-center">
                                                                    @(proposal.RespondedAtUtc.HasValue
                                                                                                                                ? proposal.RespondedAtUtc.Value.ToString("dd MMM yyyy HH:mm")
                                                                                                                                : "-")
                                                        </td>
                                                        <td class="text-center">
                                                            @if (proposal.CanApprove)
                                                                    {
                                                                        <form asp-controller="Matches"
                                                                              asp-action="ApproveVenueProposal"
                                                                              method="post"
                                                                              class="proposal-action-form">
                                                                            @Html.AntiForgeryToken()
                                                                            <input type="hidden" name="proposalId" value="@proposal.ProposalId" />
                                                                            <button type="submit" class="btn btn-success">Approve</button>
                                                                        </form>
                                                                    }

                                                                    @if (proposal.CanDecline)
                                                                    {
                                                                        <form asp-controller="Matches"
                                                                              asp-action="DeclineVenueProposal"
                                                                              method="post"
                                                                              class="proposal-action-form">
                                                                            @Html.AntiForgeryToken()
                                                                            <input type="hidden" name="proposalId" value="@proposal.ProposalId" />
                                                                            <button type="submit" class="btn btn-danger">Decline</button>
                                                                        </form>
                                                                    }

                                                                    @if (!proposal.CanApprove && !proposal.CanDecline)
                                                                    {
                                                                        <span class="match-status-badge">No action</span>
                                                                    }
                                                                </td>
                                                            </tr>
                                                        }
                                                    </tbody>
                                                </table>
                                            </div>
                                        </div>
                                    }
                                </div>
                            </div>
                        </div>

                        <div class="tab-pane" id="result-history">
                            <div class="row">
                                <div class="col-lg-12">
                                    <div class="panel-box match-table-box">
                                        <div class="titles">
                                            <h4>Result Proposal History</h4>
                                        </div>

                                        @if (!Model.ResultProposals.Any())
                                        {
                                            <div class="match-table-note">
                                                <h4>No result proposals yet</h4>
                                                <p>No team has submitted a result proposal for this match.</p>
                                            </div>
                                        }
                                        else
                                        {
                                            <div class="match-table-wrapper">
                                                <table class="table-striped table-responsive table-hover result-point">
                                                    <thead class="point-table-head">
                                                        <tr>
                                                            <th class="text-left">Proposed By</th>
                                                            <th class="text-center">Score</th>
                                                            <th class="text-center">Status</th>
                                                            <th class="text-center">Created</th>
                                                            <th class="text-center">Responded</th>
                                                        </tr>
                                                    </thead>

                                                    <tbody>
                                                        @foreach (var proposal in Model.ResultProposals)
                                                        {
                                                            <tr>
                                                                <td class="text-left">@proposal.ProposedByTeamName</td>
                                                                <td class="text-center">
                                                                    <span class="match-proposal-score">
                                                                        @proposal.ProposedHomeTeamScore - @proposal.ProposedAwayTeamScore
                                                                    </span>
                                                                </td>
                                                                <td class="text-center">@proposal.StatusText</td>
                                                                <td class="text-center">@proposal.CreatedAtUtc.ToString("dd MMM yyyy HH:mm")</td>
                                                                <td class="text-center">
                                                                    @(proposal.RespondedAtUtc.HasValue
                                                                                                                                ? proposal.RespondedAtUtc.Value.ToString("dd MMM yyyy HH:mm")
                                                                                                                                : "-")
                                                        </td>
                                                    </tr>
                                                                                                        }
                                                    </tbody>
                                                </table>
                                            </div>
                                        }
                                    </div>
                                </div>
                            </div>
                        </div>
                    </div>
                </div>
            </div>
        </div>
    </div>
</section>