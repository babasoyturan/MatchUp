@model PlayersIndexVm

@if (Model.Players.Count == 0)
{
    <div class="panel-box">
        <div class="info-panel text-center" style="padding:40px 20px;">
            <h4>No players found</h4>
            <p>Try changing the search text or filters.</p>
        </div>
    </div>

    <div data-total-count="@Model.TotalCount"></div>
}
else
{
    <div class="container padding-top" data-total-count="@Model.TotalCount">
        <div class="row portfolioContainer">
            @foreach (var player in Model.Players)
            {
                var playerImage = !string.IsNullOrWhiteSpace(player.ImageUrl)
                ? player.ImageUrl
                : Url.Content("~/img/default-player.jpg");

                <div class="col-xl-3 col-lg-4 col-md-6">
                    <div class="item-player">
                        <div class="head-player">
                            <img src="@playerImage" alt="@player.FullName">
                            <div class="overlay">
                                <a asp-controller="Players"
                                   asp-action="Details"
                                   asp-route-id="@player.Id">+</a>
                            </div>
                        </div>

                        <div class="info-player">
                            <h4>
                                @player.FullName
                                <span>@player.PrimaryPosition</span>
                            </h4>

                            <ul>
                                <li>
                                    <strong>NATIONALITY</strong>
                                    <span>@player.Nationality</span>
                                </li>
                                <li>
                                    <strong>AGE:</strong>
                                    <span>@player.Age</span>
                                </li>
                            </ul>
                        </div>

                        <a asp-controller="Players"
                           asp-action="Details"
                           asp-route-id="@player.Id"
                           class="btn">
                            View Player
                            <i class="fa fa-angle-right" aria-hidden="true"></i>
                        </a>
                    </div>
                </div>
            }
        </div>

        @if (Model.TotalPages > 1)
        {
            <div class="row">
                <div class="col-lg-12">
                    <nav aria-label="Players pagination" style="margin-top:30px;">
                        <ul class="pagination justify-content-center">
                            @for (int i = 1; i <= Model.TotalPages; i++)
                            {
                                <li class="page-item @(Model.Filter.Page == i ? "active" : "")">
                                    <a href="#"
                                       class="page-link players-page-link"
                                       data-page="@i">
                                        @i
                                    </a>
                                </li>
                            }
                        </ul>
                    </nav>
                </div>
            </div>
        }
    </div>
}