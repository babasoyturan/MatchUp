@model LoginVm

@{
    ViewData["Title"] = "Login";
}

<section class="content-info">
    <div class="container paddings">
        <div class="panel-box block-form">
            <div class="titles text-center">
                <h4>LOGIN TO YOUR ACCOUNT</h4>
            </div>

            <div class="info-panel">
                <div class="row">
                    <div class="col-md-12 text-center">
                        <p class="lead">
                            Sign in to manage your profile, teams, and match requests.
                        </p>
                    </div>
                </div>

                <form asp-controller="Account"
                      asp-action="Login"
                      method="post">

                    @Html.AntiForgeryToken()

                    @if (ViewBag.ReturnUrl != null)
                    {
                        <input type="hidden" name="returnUrl" value="@ViewBag.ReturnUrl" />
                    }

                    <div asp-validation-summary="ModelOnly" class="text-danger margin-bottom-10"></div>

                    <div class="form-group">
                        <label asp-for="Email" class="control-label col-sm-2">Email</label>
                        <div class="col-sm-10">
                            <input asp-for="Email" class="form-control" placeholder="Type your email" />
                            <span asp-validation-for="Email" class="text-danger"></span>
                        </div>
                    </div>

                    <div class="form-group">
                        <label asp-for="Password" class="control-label col-sm-2">Password</label>
                        <div class="col-sm-10">
                            <input asp-for="Password" class="form-control" placeholder="Type your password" />
                            <span asp-validation-for="Password" class="text-danger"></span>
                        </div>
                    </div>

                    <div class="form-group">
                        <div class="col-sm-offset-2 col-sm-10">
                            <button type="submit" class="bnt btn-iw">Login</button>
                        </div>
                    </div>

                    <div class="form-group">
                        <div class="col-sm-offset-2 col-sm-10">
                            <p>
                                Don’t have an account?
                                <a asp-controller="Account" asp-action="Register">Register</a>
                            </p>
                        </div>
                    </div>
                </form>
            </div>
        </div>
    </div>
</section>

@section Scripts {
    <partial name="_ValidationScriptsPartial" />
}